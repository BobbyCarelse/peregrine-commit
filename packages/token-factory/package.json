{
  "name": "@peregrine-commit/token-factory",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6010 --no-open",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@peregrine-commit/eslint-config": "workspace:*",
    "@peregrine-commit/typescript-config": "workspace:*",
    "@storybook/addon-a11y": "8.6.18",
    "@storybook/addon-essentials": "8.6.18",
    "@storybook/html": "8.6.18",
    "@storybook/html-vite": "8.6.18",
    "eslint": "^9.17.0",
    "storybook": "8.6.18",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite": "^6.4.3",
    "vitest": "^2.1.8"
  }
}
